# Infloww OpenAPI credentials
# Both are required. Generate from your Infloww desktop app under Settings > API Keys.
# These vars are read server-side only and never exposed to the browser.

INFLOW_API_KEY=sk-...
INFLOW_AGENCY_OID=1940207587098641

# MongoDB Atlas connection string (M0 free tier is fine).
# Used for influencer + weekly entry storage.
MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/eleopards?retryWrites=true&w=majority

# Single-admin login. Change these in production.
# AUTH_SECRET must be at least 32 chars of random bytes; generate with:
#   openssl rand -base64 48
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-please
AUTH_SECRET=replace-with-32-plus-chars-of-random-bytes-and-rotate-yearly
