# MongoDB Atlas connection string (M0 free tier is fine).
# Used for influencer + weekly entry storage.
MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/eleopards?retryWrites=true&w=majority

# Two-tier login. Change these in production.
# AUTH_SECRET must be at least 32 chars of random bytes; generate with:
#   openssl rand -base64 48
#
# `admin` has full access (CRUD on influencers + subreddits, syncs, entries,
# share links). `editor` has read-only access for influencers/subreddits but
# can do weekly entry, run subreddit syncs, and create share links —
# useful for ops/data-entry teammates who shouldn't be able to add or
# delete models. Editor credentials are optional; omit them to disable
# the editor login entirely.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-please
EDITOR_USERNAME=editor
EDITOR_PASSWORD=change-me-too
AUTH_SECRET=replace-with-32-plus-chars-of-random-bytes-and-rotate-yearly
