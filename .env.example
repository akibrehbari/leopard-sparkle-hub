# MongoDB Atlas connection string (M0 free tier is fine).
# Used for agencies, influencers, subreddits, weekly entry storage,
# and bcrypt-hashed agency-owner credentials.
MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/eleopards?retryWrites=true&w=majority

# Three-tier login.
#
# Two roles live here in the env:
#   admin  — full access. Creates / deletes agencies, influencers,
#            subreddits, and switches between agencies.
#   editor — restricted writer. Can switch agencies, do weekly entry,
#            run subreddit syncs, and create share links. Cannot create
#            or delete agencies / influencers / subreddits. Optional —
#            omit to disable the editor login entirely.
#
# The third role, `agency_owner`, is created via the admin UI (see the
# /agencies page) and stored in MongoDB with a bcrypt password hash.
# Each agency owner is pinned to one agency at login and gets read-only
# access to that agency's data. There are no env vars for them.
#
# AUTH_SECRET must be at least 32 chars of random bytes; generate with:
#   openssl rand -base64 48
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-please
EDITOR_USERNAME=editor
EDITOR_PASSWORD=change-me-too
AUTH_SECRET=replace-with-32-plus-chars-of-random-bytes-and-rotate-yearly
